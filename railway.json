{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install",
    "nixpacksConfig": {
      "phases": {
        "setup": {
          "nixPkgs": [
            "nodejs_22"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "node railway_start.js",
    "restartPolicyType": "ALWAYS"
  }
}
