# ============================================================
# WhaleBell 环境变量
# ============================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Server
PORT=3101
NODE_ENV=development

# Lemon Squeezy 支付 (推荐 — 护照注册)
# 1. https://app.lemonsqueezy.com/signup
# 2. Settings → API → 生成 API Key
# 3. Products → 创建产品 → 复制 Variant ID
LEMON_API_KEY=eyJ0eX...
LEMON_STORE_ID=12345
LEMON_WEEKLY_VARIANT=111111
LEMON_MONTHLY_VARIANT=222222

# 手动收款 (备用 — 零门槛)
PAY_GOPAY=0812xxxxxxxx
PAY_DANA=0812xxxxxxxx
PAY_BCA=1234567890
PAY_HOLDER=你的名字
